# OpenSquad Service Environment Variables
# Copy this file to .env and fill in the values

# Port for the service (default: 3000)
PORT=3000

# Path to opensquad repository (default: ./opensquad)
PATH_OPENSQUAD=./opensquad

# OpenAI API Key (required for OpenSquad)
OPENAI_API_KEY=sk-your-api-key-here

# Opcional: não rodar postinstall que gera static-ui (npm install mais rápido em dev)
# SKIP_POSTINSTALL_UI=1
