# Porta do servidor (Render injeta automaticamente)
PORT=3000

# Chave de criptografia para API keys salvas no banco (32 caracteres)
# GERE UM VALOR ALEATÓRIO EM PRODUÇÃO: node -e "console.log(require('crypto').randomBytes(32).toString('hex').slice(0,32))"
ENCRYPTION_KEY=mude-esta-chave-para-32-chars!!

# Caminho do banco de dados SQLite
# Em produção no Render use: /data/faroll.db  (persistent disk)
DB_PATH=./data/faroll.db

# Ambiente
NODE_ENV=development
